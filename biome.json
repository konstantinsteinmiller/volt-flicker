{
  "$schema": "https://biomejs.dev/schemas/2.4.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "tab",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf",
    "attributePosition": "multiline"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "es5",
      "arrowParentheses": "asNeeded"
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noElseReturn": "error"
      },
      "style": {
        "useTemplate": "error",
        "useBlockStatements": "error",
        "noMultiSpaces": "error"
      },
      "suspicious": {
        "noConsoleLog": "warn",
        "noDebugger": "warn"
      },
      "nursery": {
        "useVueHyphenatedAttributes": "error",
        "useVueConsistentVBindStyle": "error",
        "useVueConsistentVOnStyle": "off",
        "useVueValidVHtml": "off",
        "noVueReservedProps": "error",
        "useVueMainComponentNames": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn"
      }
    }
  },
  "overrides": [
    {
      "include": [
        "*.vue"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": {
              "options": {
                "strictCase": false
              }
            }
          },
          "nursery": {
            "useVueMainComponentNames": "off"
          }
        }
      }
    }
  ]
}