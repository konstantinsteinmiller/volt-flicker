{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,
    // Disable emitting output during `vue-tsc --build` (type-check only).
    // Without this, vue-tsc writes compiled `.js` next to every source and
    // Vite's resolver (`.js` before `.ts`) picks those stale artifacts over the
    // real sources, breaking the build with phantom "X is not exported" errors.
    "noEmit": true,
    // Path mapping for cleaner imports.
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
